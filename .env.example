# Multi-bot mode (optional)
# Set to a JSON file path to run multiple Feishu bots in one process.
BOTS_CONFIG=

# Feishu Bot Configuration (single-bot mode — used when BOTS_CONFIG is not set)
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret

# Codex Configuration
CODEX_DEFAULT_WORKING_DIRECTORY=/path/to/your/project
CODEX_ALLOWED_TOOLS=Read,Edit,Write,Glob,Grep,Bash,WebSearch,WebFetch
CODEX_MAX_TURNS=50
CODEX_MAX_BUDGET_USD=1.0
CODEX_MODEL=
# Optional override for codex CLI path
# CODEX_EXECUTABLE_PATH=/Applications/Codex.app/Contents/Resources/codex

# Outputs directory (files placed here by agent are auto-sent to chat)
OUTPUTS_BASE_DIR=

# Memory server URL (MetaMemory document server)
# MEMORY_SERVER_URL=http://localhost:8100

# HTTP API (inter-bot communication & scheduling)
API_PORT=9100
API_SECRET=       # If set, listens on 0.0.0.0 with Bearer auth; if empty, localhost only

# Default timezone for recurring cron tasks (IANA format)
# SCHEDULE_TIMEZONE=Asia/Shanghai

# Logging
LOG_LEVEL=info
