#!/usr/bin/env bash
# codexbot - CodexBot management CLI
# Usage: codexbot update | start | stop | restart | logs | status

set -euo pipefail

METABOT_HOME="${METABOT_HOME:-$HOME/codexbot}"

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()    { echo -e "${BLUE}[INFO]${NC} $*"; }
success() { echo -e "${GREEN}[OK]${NC} $*"; }
error()   { echo -e "${RED}[ERROR]${NC} $*"; }

cmd_update() {
  if [[ ! -d "$METABOT_HOME/.git" ]]; then
    error "CodexBot not found at $METABOT_HOME"
    echo "  Run the installer first: curl -fsSL https://raw.githubusercontent.com/FreemanHsu/codexbot/main/install.sh | bash"
    exit 1
  fi

  info "Pulling latest code..."
  cd "$METABOT_HOME"
  git pull --ff-only || { error "git pull failed"; exit 1; }

  info "Installing dependencies..."
  npm install --production=false

  info "Building..."
  npm run build

  info "Restarting CodexBot..."
  pm2 restart codexbot 2>/dev/null || pm2 start ecosystem.config.cjs
  pm2 save --force 2>/dev/null || true

  success "CodexBot updated and restarted!"
}

cmd_start()   { pm2 start "$METABOT_HOME/ecosystem.config.cjs"; pm2 save --force 2>/dev/null || true; }
cmd_stop()    { pm2 stop codexbot; }
cmd_restart() { pm2 restart codexbot; }
cmd_logs()    { pm2 logs codexbot "${@}"; }
cmd_status()  { pm2 describe codexbot; }

case "${1:-help}" in
  update|up)    cmd_update ;;
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  restart|rs)   cmd_restart ;;
  logs|log)     shift; cmd_logs "$@" ;;
  status|st)    cmd_status ;;
  *)
    echo -e "${BOLD}codexbot${NC} - CodexBot management CLI"
    echo ""
    echo "  codexbot update     Pull latest, rebuild, and restart"
    echo "  codexbot start      Start CodexBot with PM2"
    echo "  codexbot stop       Stop CodexBot"
    echo "  codexbot restart    Restart CodexBot"
    echo "  codexbot logs       View live logs (pass -n 100 etc.)"
    echo "  codexbot status     Show PM2 process status"
    ;;
esac
